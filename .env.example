# ==========================================
# FOOD DASH - Docker Environment Configuration
# Copy this file to .env and fill in your values
# ==========================================

# ============ Node.js Environment ============
NODE_ENV=production
PORT=5000

# ============ Database Configuration ============
# Local MongoDB
MONGODB_URI=mongodb://admin:password@mongodb:27017/food_dash?authSource=admin

# OR MongoDB Atlas (uncomment to use)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/food_dash?retryWrites=true

# MongoDB Docker Credentials
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password

# ============ Redis Configuration ============
# Docker Redis
REDIS_URL=redis://:redis_password@redis:6379

# OR Cloud Redis (uncomment to use)
# REDIS_URL=redis://:your_password@host:6379
REDIS_PASSWORD=redis_password

# ============ JWT & Authentication ============
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_change_me_immediately
JWT_EXPIRE=7d

# ============ Google OAuth 2.0 ============
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============ Razorpay Payment Gateway ============
# Get from https://dashboard.razorpay.com/settings/api-keys
# Use TEST keys in development, LIVE keys in production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ============ OpenAI API (for Recommendations) ============
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ Email Configuration (Gmail SMTP) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use "App Passwords" if you have 2FA enabled
SMTP_PASSWORD=your_app_password

# ============ Python OpenEnv Configuration ============
PYTHON_PORT=8000
NODE_API_URL=http://localhost:5000

# ============ Logging Configuration ============
LOG_LEVEL=debug
LOG_DIR=./server/logs

# ============ CORS Configuration ============
# Frontend URLs allowed to access backend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost,http://localhost:3000

# ============ Optional: Sentry Error Tracking ============
SENTRY_DSN=

# ============ Optional: Analytics ============
GOOGLE_ANALYTICS_ID=

# ============ Optional: File Upload Configuration ============
MAX_FILE_SIZE=50000000
UPLOAD_DIR=./server/database/uploads

# ============ Optional: Session Configuration ============
SESSION_SECRET=your_session_secret_key_here
SESSION_TIMEOUT=3600000

# ============ Optional: Rate Limiting ============
RATE_LIMIT_WINDOW_MS=30000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SENSITIVE_MAX=10

# ============ Docker Specific ============
COMPOSE_PROJECT_NAME=food-dash
